import datetime
import time

current_time = ""

active = True
while active == True:
    new_time = datetime.datetime.now().strftime("%B %d %I:%M %p")

    if current_time != new_time:
        current_time = new_time
        print(current_time)

    time.sleep(1)

    print("Session Active: y/n")
    user_input = input()

    while user_input != "y" and user_input != "n":
        user_input = input().lower()
    
    if user_input == "y":
        active = True
    else: 
        active = False